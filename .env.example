# SailPoint Configuration
SAIL_BASE_URL=https://your-tenant.api.identitynow.com
SAIL_CLIENT_ID=your_oauth_client_id_here
SAIL_CLIENT_SECRET=your_oauth_client_secret_here
OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback
# Authorization and token URLs are discovered from OAUTH_INFO_URL.
# Defaults to {SAIL_BASE_URL}/oauth/info if not set.
OAUTH_INFO_URL=https://your-tenant.api.identitynow.com/oauth/info

# Application Configuration
SESSION_SECRET=generate-a-long-random-string-here
APP_ENV=development
LOG_LEVEL=INFO

# Optional: Redis (for production session storage)
# REDIS_URL=redis://localhost:6379/0

# Optional: Database (for config persistence)
# DATABASE_URL=postgresql://user:pass@localhost/sailpoint_app
